{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yersonargotev.github.io/packy/schemas/cli/v2/classic-lifecycle.schema.json",
  "title": "Packy classic lifecycle report v2",
  "$defs": {
    "transition": {
      "type": "object",
      "required": ["from_schema_version", "to_schema_version", "from_status", "to_status"],
      "properties": {
        "from_schema_version": {"type": "integer", "minimum": 0},
        "to_schema_version": {"type": "integer", "minimum": 0},
        "from_status": {"type": "string"},
        "to_status": {"type": "string"}
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["kind", "description"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "path": {"type": "string"},
        "target": {"type": "string"},
        "command": {"type": "string"},
        "args": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "common": {
      "type": "object",
      "required": ["schema_version", "report", "operation", "outcome", "desired_surfaces", "pending_prerequisites", "preserved", "blockers", "recovery", "state_transition"],
      "properties": {
        "schema_version": {"const": 2},
        "report": {"enum": ["classic-lifecycle-preview", "classic-lifecycle-result"]},
        "operation": {"enum": ["install", "update", "uninstall"]},
        "outcome": {"enum": ["converged", "applied", "applied-with-pending-prerequisite", "blocked", "partially-applied", "rolled-back", "recovery-required", "uninstall-incomplete"]},
        "desired_surfaces": {"type": "array", "items": {"enum": ["claude", "codex", "opencode"]}, "uniqueItems": true},
        "pending_prerequisites": {"type": "array", "items": {"type": "string"}},
        "preserved": {"type": "array", "items": {"type": "string"}},
        "blockers": {"type": "array", "items": {"type": "string"}},
        "recovery": {"type": "array", "items": {"type": "string"}},
        "state_transition": {"$ref": "#/$defs/transition"}
      }
    }
  },
  "oneOf": [
    {
      "allOf": [{"$ref": "#/$defs/common"}],
      "required": ["actions", "dry_run"],
      "properties": {"report": {"const": "classic-lifecycle-preview"}, "actions": {"type": "array", "items": {"$ref": "#/$defs/action"}}, "dry_run": {"const": true}},
      "unevaluatedProperties": false
    },
    {
      "allOf": [{"$ref": "#/$defs/common"}],
      "required": ["committed", "completed_effects", "not_started_effects", "warnings", "managed_skill_count"],
      "properties": {
        "report": {"const": "classic-lifecycle-result"},
        "committed": {"type": "boolean"},
        "completed_effects": {"type": "array", "items": {"type": "string"}},
        "failed_effect": {"type": "string"},
        "not_started_effects": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "managed_skill_count": {"type": "integer", "minimum": 0}
      },
      "unevaluatedProperties": false
    }
  ]
}
