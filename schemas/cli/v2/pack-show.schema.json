{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yersonargotev.github.io/packy/schemas/cli/v2/pack-show.schema.json",
  "title": "Packy pack show report v2",
  "type": "object",
  "required": [
    "schema_version",
    "report",
    "catalog_state",
    "id",
    "version",
    "description",
    "source_identity",
    "historical_versions",
    "update_routes",
    "surfaces",
    "provides",
    "requires",
    "conflicts",
    "resource_counts",
    "lifecycle_availability",
    "surface_contracts"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "report": {
      "const": "pack-show"
    },
    "catalog_state": {
      "enum": [
        "current",
        "withdrawn"
      ]
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source_identity": {
      "type": "object",
      "required": [
        "pack_id",
        "version",
        "schema_version",
        "limitation"
      ],
      "properties": {
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "limitation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "historical_versions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "update_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from_version",
          "to_version",
          "existing_surfaces"
        ],
        "properties": {
          "from_version": {
            "type": "string",
            "minLength": 1
          },
          "to_version": {
            "type": "string",
            "minLength": 1
          },
          "existing_surfaces": {
            "type": "array",
            "items": {
              "enum": [
                "claude",
                "codex",
                "opencode"
              ]
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "surfaces": {
      "type": "array",
      "items": {
        "enum": [
          "claude",
          "codex",
          "opencode"
        ]
      },
      "uniqueItems": true
    },
    "provides": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "requires": {
      "type": "object",
      "required": [
        "capabilities",
        "tools"
      ],
      "properties": {
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
        },
          "tools": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "resource_counts": {
      "$ref": "lifecycle-contract.schema.json#/$defs/counts"
    },
    "lifecycle_availability": {
      "type": "object",
      "required": [
        "fresh_activation_available",
        "catalog_update_available",
        "lifecycle_verbs_available",
        "automatic_downgrade"
      ],
      "properties": {
        "fresh_activation_available": {
          "type": "boolean"
        },
        "catalog_update_available": {
          "type": "boolean"
        },
        "lifecycle_verbs_available": {
          "const": true
        },
        "automatic_downgrade": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "surface_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "surface",
          "contract",
          "intent"
        ],
        "properties": {
          "surface": {
            "enum": [
              "claude",
              "codex",
              "opencode"
            ]
          },
          "contract": {
            "$ref": "lifecycle-contract.schema.json"
          },
          "intent": {
            "type": "object",
            "required": [
              "state",
              "active",
              "revision",
              "aliases"
            ],
            "properties": {
              "state": {
                "enum": [
                  "absent",
                  "known"
                ]
              },
              "active": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "version": {
                "type": "string"
              },
              "revision": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "aliases": {
                "type": "array",
                "items": {
                  "$ref": "lifecycle-contract.schema.json#/$defs/alias"
                },
                "uniqueItems": true
              }
            },
            "oneOf": [
              {
                "properties": {
                  "state": {
                    "const": "absent"
                  },
                  "active": {
                    "type": "null"
                  },
                  "revision": {
                    "type": "null"
                  }
                },
                "not": {
                  "required": [
                    "version"
                  ]
                }
              },
              {
                "required": [
                  "version"
                ],
                "properties": {
                  "state": {
                    "const": "known"
                  },
                  "active": {
                    "type": "boolean"
                  },
                  "version": {
                    "type": "string",
                    "minLength": 1
                  },
                  "revision": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            ],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
