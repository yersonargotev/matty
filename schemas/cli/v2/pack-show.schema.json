{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yersonargotev.github.io/packy/schemas/cli/v2/pack-show.schema.json",
  "title": "Packy pack show report v2",
  "type": "object",
  "required": [
    "schema_version",
    "report",
    "id",
    "version",
    "description",
    "surfaces",
    "provides",
    "requires",
    "conflicts",
    "resource_counts",
    "surface_contracts"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "report": {
      "const": "pack-show"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "enum": [
          "claude",
          "codex",
          "opencode"
        ]
      },
      "uniqueItems": true
    },
    "provides": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires": {
      "type": "object",
      "required": [
        "capabilities",
        "tools"
      ],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resource_counts": {
      "$ref": "lifecycle-contract.schema.json#/$defs/counts"
    },
    "surface_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "surface",
          "contract"
        ],
        "properties": {
          "surface": {
            "enum": [
              "claude",
              "codex",
              "opencode"
            ]
          },
          "contract": {
            "$ref": "lifecycle-contract.schema.json"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
