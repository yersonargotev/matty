$ python3 - <<'PY'
import json,os,pathlib
p=pathlib.Path.home()/'.matty/config.json'
data=json.loads(p.read_text())
mismatches=[]
for item in data.get('managed_skills',[]):
    link=pathlib.Path(item['link_path'])
    expected=item['source_path']
    if not link.is_symlink() or os.path.realpath(link) != os.path.realpath(expected):
        mismatches.append({'name':item['name'],'link':str(link),'expected':expected,'observed':os.path.realpath(link) if link.exists() else 'missing'})
print({'recorded_links':len(data.get('managed_skills',[])),'mismatches':mismatches})
PY
